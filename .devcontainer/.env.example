# ==================================================================
# Terminal Claude Sync Development Environment Configuration
# ==================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==================================================================

# ------------------------------------------------------------------
# User Configuration (for Docker volume permissions)
# ------------------------------------------------------------------
# Your host user UID and GID (auto-detected by initializeCommand)
# Leave blank to use defaults (1000)
UID=
GID=

# ------------------------------------------------------------------
# Feishu Configuration (required)
# ------------------------------------------------------------------
# Your Feishu App ID and Secret
# Get from: https://open.feishu.cn/app
APP_ID=
APP_SECRET=

# ------------------------------------------------------------------
# Claude Code Configuration (required)
# ------------------------------------------------------------------
# Auth Token for Claude Code
# Get your API key from https://console.anthropic.com/
ANTHROPIC_AUTH_TOKEN=

# API Base URL (optional, for proxy/enterprise endpoints)
# Default: https://api.anthropic.com
ANTHROPIC_BASE_URL=

# ------------------------------------------------------------------
# Bridge Server Configuration
# ------------------------------------------------------------------
# Bridge server port (default: 8082)
BRIDGE_PORT=8082