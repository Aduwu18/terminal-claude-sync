{
    "name": "Terminal Claude Sync Env",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "context": "..",
    "workspaceFolder": "/app/terminal-claude-sync",
    "remoteUser": "developer",
    "initializeCommand": "test -f .devcontainer/.env || cp .env.example .devcontainer/.env",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "donjayamanne.githistory",
                "eamodio.gitlens"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "terminal.integrated.defaultProfile.linux": "bash"
            }
        }
    },
    "postCreateCommand": "pip install -r requirements.txt"
}